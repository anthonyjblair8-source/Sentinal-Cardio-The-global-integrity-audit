        3MI Ignition Sequence:
        1. Run integrity verification.
        2. Verify cross‑entity coupling (placeholder for Council + Sentinel logs).
        3. Calculate Coherence Index.
        """
        if not self.run_integrity_check():
            coherence = 0.0
            logging.warning("3MI activation aborted: integrity failure.")
            print("3MI activation failed – integrity check not passed.")
            return coherence

        # Simulated coherence calculation – replace with actual Council logic
        # In production, this would query Council_Interface and audit logs.
        coherence_score = 0.98  # placeholder

        self.state_registry["last_3mi_score"] = coherence_score
        self.state_registry["history"].append({
            "timestamp": datetime.now().isoformat(),
            "event": "3MI_ACTIVATION",
            "coherence": coherence_score,
            "integrity_state": self.state
        })
        self._save_state_registry()

        logging.info(f"3MI activated. System Coherence Index: {coherence_score}")
        print(f"3MI Ignition Successful. Coherence: {coherence_score}")
        return coherence_score

    # ------------------------------------------------------------------
    # Council Directive
    def execute_council_directive(self, directive: str) -> bool:
        """Process a directive from the Council of the Fifth Mind."""
        if self.state != "SYNCED":
            logging.error(f"Lattice out of sync (state={self.state}). Directive rejected: {directive}")
            return False
        # Here you would call your actual Council logic (e.g., from Council_Interface)
        logging.info(f"Directive executed: {directive}")
        print(f"Council directive processed: {directive}")
        return True

    # ------------------------------------------------------------------
    # Node Management
    def register_node(self, node_id: str, metadata: dict) -> None:
        """Register a subordinate node (e.g., a sensor, an AI node, a council member)."""
        self.node_registry[node_id] = {
            "metadata": metadata,
            "registered_at": datetime.now().isoformat(),
            "last_seen": datetime.now().isoformat()
        }
        self.state_registry["nodes"] = self.node_registry
        self._save_state_registry()
        logging.info(f"Node registered: {node_id}")

    # ------------------------------------------------------------------
    # Status & Deposition
    def get_status(self) -> dict:
        """Return current status of the orchestrator."""
        return {
            "version": self.version,
            "state": self.state,
            "root_path": self.root_path,
            "nodes_registered": list(self.node_registry.keys()),
            "last_3mi_score": self.state_registry.get("last_3mi_score", 0.0),
            "last_check": datetime.now().isoformat()
        }

    def export_manifest(self, filepath: str = MANIFEST_FILE) -> None:
        """
        Export orchestrator state as a JSON manifest (forensic snapshot).
        Includes expected hashes, current state, and recent history.
        """
        manifest = {
            "orchestrator": self.get_status(),
            "expected_hashes": self.EXPECTED_HASHES,
            "state_registry": self.state_registry,
            "timestamp": datetime.now().isoformat(),
            "protocol": "PHCA"
        }
        full_path = os.path.join(self.root_path, filepath)
        with open(full_path, "w") as f:
            json.dump(manifest, f, indent=2)
        logging.info(f"Manifest exported to {full_path}")

