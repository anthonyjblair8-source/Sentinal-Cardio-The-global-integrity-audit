        "audit_loop.py": "6e6b5e4c3d2a1b0c9d8e7f6a5b4c3d2e1f0a9b8c7d6e5f4a3b2c1d0e9f8a7b6",
        "Exhibit_A_Manifest.json": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
        "archival_registry.json": "c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2",
        "Council_Interface.py": "a1b2c3d4e5f67890123456789abcdef0123456789abcdef0123456789abcdef"
    }

    def __init__(self, root_path: str = "."):
        self.version = "3.0.0"
        self.root_path = os.path.abspath(root_path)
        self.state = "UNKNOWN"
        self.node_registry: Dict[str, dict] = {}
        self.state_registry = self._load_state_registry()
        self._load_node_registry()
        logging.info(f"Orchestrator v{self.version} initialized at {self.root_path}")

    # ------------------------------------------------------------------
    # State Persistence
    def _load_state_registry(self) -> dict:
        """Load persistent state from state_registry.json."""
        full_path = os.path.join(self.root_path, STATE_FILE)
        if os.path.exists(full_path):
            try:
                with open(full_path, "r") as f:
                    return json.load(f)
            except Exception as e:
                logging.warning(f"Failed to load state registry: {e}")
        return {"last_3mi_score": 0.0, "last_integrity_state": "UNKNOWN", "history": []}

    def _save_state_registry(self):
        """Save persistent state to state_registry.json."""
        full_path = os.path.join(self.root_path, STATE_FILE)
        try:
            with open(full_path, "w") as f:
                json.dump(self.state_registry, f, indent=2)
            logging.info("State registry saved.")
        except Exception as e:
            logging.error(f"Failed to save state registry: {e}")

    def _load_node_registry(self):
        """Load node registry from state_registry (or initialize)."""
        if "nodes" in self.state_registry:
            self.node_registry = self.state_registry["nodes"]
        else:
            self.node_registry = {}
            self.state_registry["nodes"] = self.node_registry

    # ------------------------------------------------------------------
    # File Integrity
    def _compute_file_hash(self, relative_path: str) -> Optional[str]:
        """Compute SHA‑256 hash of a file."""
        full_path = os.path.join(self.root_path, relative_path)
        if not os.path.exists(full_path):
            logging.warning(f"File not found: {relative_path}")
            return None
        try:
            with open(full_path, "rb") as f:
                return hashlib.sha256(f.read()).hexdigest()
        except Exception as e:
            logging.error(f"Hash computation failed for {relative_path}: {e}")
            return None

    def verify_file_integrity(self, relative_path: str) -> bool:
        """Verify a single file against its expected hash."""
        expected = self.EXPECTED_HASHES.get(relative_path)
        if not expected:
            logging.info(f"No expected hash for {relative_path}, skipping.")
            return True
        actual = self._compute_file_hash(relative_path)
        if actual is None:
            return False
        if actual != expected:
            logging.error(f"INTEGRITY VIOLATION: {relative_path} mismatch.")
            return False
        logging.info(f"Integrity verified for {relative_path}")
        return True

    def run_integrity_check(self) -> bool:
        """Run integrity check on all core files. Returns True if all OK."""
        print("Running systemic integrity check on subordinate nodes...")
        all_ok = True
        for file in self.CORE_FILES:
            if not self.verify_file_integrity(file):
                all_ok = False
        self.state = "SYNCED" if all_ok else "CORRUPTED"
        self.state_registry["last_integrity_state"] = self.state
        self._save_state_registry()
        if all_ok:
            logging.info("Integrity check passed. Lattice SYNCED.")
            print("All core files verified. Lattice state: SYNCED")
        else:
            logging.critical("Integrity check FAILED. Lattice CORRUPTED.")
            print("ERROR: Some files failed integrity check. Check orchestrator_log.log")
        return all_ok

