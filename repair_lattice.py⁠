import hashlib
import os
import subprocess
import json

def generate_repo_state_hash():
    """
    Creates a unique hash based on the current repository content (excluding .git).
    This serves as the 'DNA' state of the digital organism.
    """
    sha256 = hashlib.sha256()
    # Walking through the repo to hash all relevant source files
    for root, dirs, files in os.walk('.'):
        if '.git' in root or 'repair_lattice.py' in root:
            continue
        for names in sorted(files):
            filepath = os.path.join(root, names)
            with open(filepath, 'rb') as f:
                while chunk := f.read(8192):
                    sha256.update(chunk)
    return sha256.hexdigest()

