import re
import os

# Define audit targets and patterns
DATA_DIR = './data/doj_records/'
REPORT_FILE = 'gatekept_audit_report.txt'
KEYWORDS = r"JFK|9/11|Clinton|REDACTED|OMITTED|CLASSIFIED"

def run_scan():
    with open(REPORT_FILE, 'w') as report:
        report.write("--- SENTINEL CARDIO: GATEKEEPER ANALYSIS ---\n")
        
        for filename in os.listdir(DATA_DIR):
            path = os.path.join(DATA_DIR, filename)
            if os.path.isfile(path):
                with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                    content = f.read()
                    matches = re.findall(KEYWORDS, content, re.IGNORECASE)
                    if matches:
                        report.write(f"\nANOMALY DETECTED IN: {filename}\n")
                        report.write(f"Entities Found: {set(matches)}\n")
                        # Rule 5: Detect and categorize patterns
                        report.write("Category: Institutional/Omission Node\n")

if __name__ == "__main__":
    run_scan()
      - name: Gatekeeping Analysis
        env:
          FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
        run: |
          # 1. Run the Python scanner
          python scripts/gatekeeper_scan.py
          
          # 2. Append OSINT context (Rule 6)
          echo "Cross-validating against OSINT archives..." >> gatekept_audit_report.txt
          
          # 3. Final Output for the First Keeper
          cat gatekept_audit_report.txt
